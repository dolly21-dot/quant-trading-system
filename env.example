# Trading 212 API Configuration
T212_API_KEY=your_api_key_here
T212_ENVIRONMENT=demo  # demo or live

# Data Sources
NEWS_API_KEY=your_news_api_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# Risk Parameters
MAX_POSITION_PCT=0.10          # 单只股票最大仓位占比
MAX_PORTFOLIO_RISK_PCT=0.02    # 单笔交易最大风险占比
STOP_LOSS_PCT=0.05             # 默认止损百分比
TAKE_PROFIT_PCT=0.10           # 默认止盈百分比

# Database
DB_PATH=./data/quant_system.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/system.log

# Notifications
NOTIFY_EMAIL=your_email@example.com
